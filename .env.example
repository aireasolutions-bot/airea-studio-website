# Copy to .env.local and fill in. All VITE_* vars are bundled into the client
# (safe-to-expose values only). Set the same three in Vercel.

# Supabase (public anon access — protected by Row Level Security)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Cloudflare R2 public base URL for media assets.
# Leave empty to serve assets from /public/assets (local dev / Vercel static).
VITE_ASSETS_BASE_URL=

# ─────────────────────────────────────────────────────────────────────────────
# SERVER-ONLY (no VITE_ prefix — never bundled to the browser). Set in Vercel.
# Used by /api/upload and /api/agent/*. Real values live in git-ignored files
# (.env.agent.local, .env.r2.local) and CREDENTIALS.local.md.
# ─────────────────────────────────────────────────────────────────────────────
# Supabase admin verification (shared by upload + agent)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE=
# AIREA Agent — website builder (/api/agent/*)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1
# GITHUB_TOKEN=
# GITHUB_REPO=owner/repo
# GITHUB_BRANCH=main
